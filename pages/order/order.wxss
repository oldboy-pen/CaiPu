/* 订单页面样式 */
/* 空订单 */
.empty-orders {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.empty-btn {
  padding: 20rpx 60rpx;
  background-color: #FF6B6B;
  color: #fff;
  border-radius: 50rpx;
  font-size: 28rpx;
}

/* 订单列表 */
.orders-content {
  padding: 20rpx;
}

.order-item {
  margin-bottom: 20rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #eee;
  margin-bottom: 20rpx;
}

.order-time {
  font-size: 24rpx;
  color: #666;
}

.order-status {
  font-size: 24rpx;
  color: #FF6B6B;
  font-weight: bold;
}

.order-status.completed {
  color: #52C41A;
}

/* 订单菜品预览 */
.order-items {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.item-preview {
  width: 80rpx;
  height: 80rpx;
  margin-right: 12rpx;
}

.preview-image {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
}

.more-items {
  width: 80rpx;
  height: 80rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #999;
}

/* 订单信息 */
.order-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.order-count {
  font-size: 26rpx;
  color: #666;
}

.order-price {
  font-size: 36rpx;
  color: #FF6B6B;
  font-weight: bold;
}

/* 订单操作按钮 */
.order-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}

.action-btn {
  padding: 10rpx 32rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
}

.action-btn.primary {
  background-color: #FF6B6B;
  color: #fff;
}

.action-btn.secondary {
  background-color: #f5f5f5;
  color: #666;
}
