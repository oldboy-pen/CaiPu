/* 分类页面样式 */
.category-page {
  display: flex;
  height: 100vh;
  padding-bottom: 0;
}

/* 左侧分类栏 */
.category-sidebar {
  width: 180rpx;
  background-color: #f5f5f5;
  height: 100%;
}

.category-item {
  padding: 30rpx 20rpx;
  text-align: center;
  border-bottom: 2rpx solid #eee;
}

.category-item.active {
  background-color: #fff;
  color: #FF6B6B;
}

.category-icon {
  display: block;
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.category-name {
  font-size: 24rpx;
}

/* 右侧菜品列表 */
.dish-list {
  flex: 1;
  height: 100%;
  padding: 20rpx;
  box-sizing: border-box;
}

.dish-item {
  display: flex;
  margin-bottom: 20rpx;
  padding: 20rpx;
  min-height: 220rpx;
}

.dish-image-wrapper {
  width: 180rpx;
  height: 180rpx;
  flex-shrink: 0;
  position: relative;
}

.dish-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
}

.dish-placeholder {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  background-color: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-emoji {
  font-size: 80rpx;
}

.dish-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.dish-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6rpx;
}

.dish-name {
  font-size: 30rpx;
  font-weight: bold;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rating {
  display: flex;
  align-items: center;
}

.rating-star {
  color: #FFA500;
  font-size: 22rpx;
  margin-right: 4rpx;
}

.rating-score {
  color: #FFA500;
  font-size: 22rpx;
  font-weight: bold;
}

.dish-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dish-tags {
  margin: 6rpx 0;
}

.tag {
  display: inline-block;
  padding: 2rpx 10rpx;
  font-size: 18rpx;
  color: #FF6B6B;
  border: 1rpx solid #FF6B6B;
  border-radius: 4rpx;
  margin-right: 6rpx;
}

.tag.hot-tag {
  background-color: #FF6B6B;
  color: #fff;
}

.dish-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.price-info {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
  margin-right: 10rpx;
}

.price-wrapper {
  display: flex;
  align-items: baseline;
}

.dish-price {
  color: #FF6B6B;
  font-size: 28rpx;
  font-weight: bold;
  margin-right: 6rpx;
}

.original-price {
  color: #999;
  font-size: 18rpx;
  text-decoration: line-through;
}

.dish-sold {
  font-size: 18rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.add-btn {
  padding: 8rpx 18rpx;
  background-color: #FF6B6B;
  color: #fff;
  border-radius: 30rpx;
  font-size: 20rpx;
  white-space: nowrap;
  flex-shrink: 0;
  min-width: 120rpx;
  text-align: center;
}
