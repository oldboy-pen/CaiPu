<view class="container">
  <!-- 空购物车状态 -->
  <view class="empty-cart" wx:if="{{isEmpty}}">
    <text class="empty-icon">🛒</text>
    <text class="empty-text">购物车是空的</text>
    <view class="empty-btn" bindtap="goToCategory">去点菜</view>
  </view>

  <!-- 购物车列表 -->
  <view class="cart-content" wx:else>
    <view class="cart-header">
      <text>购物车</text>
      <text class="clear-btn" bindtap="clearCart">清空</text>
    </view>

    <scroll-view class="cart-list" scroll-y>
      <view class="cart-item card" wx:for="{{cart}}" wx:key="id">
        <image class="item-image" src="{{item.image}}" mode="aspectFill"></image>
        <view class="item-info">
          <text class="item-name">{{item.name}}</text>
          <text class="item-price">¥{{item.price}}</text>
        </view>
        <view class="item-action">
          <view class="quantity-control">
            <text class="quantity-btn" bindtap="decrease" data-index="{{index}}">-</text>
            <text class="quantity">{{item.count}}</text>
            <text class="quantity-btn" bindtap="increase" data-index="{{index}}">+</text>
          </view>
        </view>
      </view>
    </scroll-view>

    <!-- 底部结算栏 -->
    <view class="cart-footer">
      <view class="total-info">
        <text class="total-text">合计:</text>
        <text class="total-price">¥{{totalPrice}}</text>
        <text class="total-count">共{{totalCount}}份</text>
      </view>
      <view class="checkout-btn" bindtap="checkout">去结算</view>
    </view>
  </view>
</view>
