/* 首页样式 */
.banner {
  width: 100%;
  height: 360rpx;
}

.banner-image {
  width: 100%;
  height: 100%;
}

/* 快捷导航 */
.quick-nav {
  display: flex;
  justify-content: space-around;
  padding: 40rpx 0;
  background-color: #fff;
  margin-bottom: 20rpx;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.nav-icon {
  font-size: 56rpx;
  margin-bottom: 10rpx;
}

.nav-text {
  font-size: 24rpx;
  color: #666;
}

/* 分类标题 */
.section {
  margin-bottom: 20rpx;
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 30rpx 20rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.more {
  font-size: 24rpx;
  color: #999;
  font-weight: normal;
}

/* 推荐菜品横向滚动 */
.recommend-scroll {
  white-space: nowrap;
  padding: 0 20rpx;
}

.recommend-item {
  display: inline-block;
  width: 240rpx;
  margin-right: 20rpx;
  position: relative;
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.dish-image-wrapper {
  width: 240rpx;
  height: 240rpx;
  position: relative;
}

.dish-image {
  width: 240rpx;
  height: 240rpx;
  display: block;
}

.dish-placeholder {
  width: 240rpx;
  height: 240rpx;
  background-color: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-emoji {
  font-size: 100rpx;
}

.dish-info {
  padding: 16rpx;
}

.dish-name {
  font-size: 28rpx;
  font-weight: bold;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dish-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 10rpx;
}

.price-wrapper {
  display: flex;
  align-items: baseline;
}

.dish-price {
  color: #FF6B6B;
  font-size: 28rpx;
  font-weight: bold;
}

.original-price {
  color: #999;
  font-size: 20rpx;
  text-decoration: line-through;
  margin-left: 6rpx;
}

.dish-sold {
  font-size: 20rpx;
  color: #999;
}

.dish-tags {
  margin: 8rpx 0;
}

.tag {
  display: inline-block;
  padding: 2rpx 8rpx;
  font-size: 18rpx;
  color: #FF6B6B;
  border: 1rpx solid #FF6B6B;
  border-radius: 4rpx;
  margin-right: 6rpx;
}

.tag.hot-tag {
  background-color: #FF6B6B;
  color: #fff;
}

.add-btn {
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  width: 48rpx;
  height: 48rpx;
  background-color: #FF6B6B;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: bold;
}

/* 热门菜品列表 */
.hot-list {
  padding: 0 20rpx;
}

.hot-item {
  display: flex;
  margin-bottom: 20rpx;
}

.hot-image-wrapper {
  width: 200rpx;
  height: 200rpx;
  flex-shrink: 0;
  position: relative;
}

.hot-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
}

.hot-placeholder {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  background-color: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hot-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.hot-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.hot-name {
  font-size: 30rpx;
  font-weight: bold;
  flex: 1;
}

.rating {
  display: flex;
  align-items: center;
}

.rating-star {
  color: #FFA500;
  font-size: 24rpx;
  margin-right: 4rpx;
}

.rating-score {
  color: #FFA500;
  font-size: 24rpx;
  font-weight: bold;
}

.hot-desc {
  font-size: 24rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.hot-tags {
  margin: 8rpx 0;
}

.hot-tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  font-size: 20rpx;
  color: #FF6B6B;
  border: 1rpx solid #FF6B6B;
  border-radius: 6rpx;
  margin-right: 8rpx;
  margin-bottom: 8rpx;
}

.hot-tag.hot-tag {
  background-color: #FF6B6B;
  color: #fff;
}

.hot-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.price-wrapper {
  display: flex;
  align-items: baseline;
}

.hot-price {
  color: #FF6B6B;
  font-size: 32rpx;
  font-weight: bold;
}

.hot-original-price {
  color: #999;
  font-size: 22rpx;
  text-decoration: line-through;
  margin-left: 8rpx;
}

.add-btn-small {
  padding: 8rpx 24rpx;
  background-color: #FF6B6B;
  color: #fff;
  border-radius: 40rpx;
  font-size: 24rpx;
}
